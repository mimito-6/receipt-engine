{
  "name": "@receipt-engine/react",
  "private": true,
  "version": "0.1.0",
  "description": "React component that renders a receipt-engine document as an inline SVG card.",
  "license": "MIT",
  "author": "mimito",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@receipt-engine/core": "workspace:*",
    "@receipt-engine/render-svg": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1"
  }
}
