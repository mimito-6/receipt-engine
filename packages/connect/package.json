{
  "name": "@receipt-engine/connect",
  "version": "0.1.0",
  "description": "Browser delivery for receipt-engine: Web Bluetooth ESC/POS thermal printing and Web Share to a phone, plus SVG→ImageData/PNG canvas helpers.",
  "license": "MIT",
  "author": "mimito",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@receipt-engine/bitmap": "workspace:*",
    "@receipt-engine/escpos": "workspace:*"
  }
}
