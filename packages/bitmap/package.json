{
  "name": "@receipt-engine/bitmap",
  "private": true,
  "version": "0.1.0",
  "description": "Convert RGBA pixels to a 1-bpp thermal bitmap (luminance + threshold / Floyd–Steinberg / Atkinson dithering, MSB-first packing). Dependency-free and isomorphic.",
  "license": "MIT",
  "author": "mimito",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
